{
  "name": "@alialkhtri3-png/sip-runtime",
  "version": "1.0.7",
  "description": "Sovereign Identity Protocol - Ethereum DID, Verifiable Credentials and Identity Network",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test:sip-network": "node protocol/v22/mesh/test-network.js",
    "sip-node": "node protocol/v23/cli/sip.js",
    "sip-cluster": "node protocol/v24/cli/cluster.js",
    "sip-consensus": "node protocol/v25/cli/consensus.js",
    "sip-governance": "node protocol/v26/cli/governance.js",
    "sip-security": "node protocol/v27/cli/security.js",
    "sip-economy": "node protocol/v28/cli/economy.js",
    "sip-market": "node protocol/v29/cli/market.js",
    "sip-runtime": "node protocol/v30/cli/sip.js",
    "build:contracts": "forge build",
    "test:contracts": "forge test",
    "build": "npm run build:contracts",
    "test:all": "npm run test:contracts && npm run test:sip-network"
  },
  "dependencies": {
    "@alialkhtri3-png/sip-runtime": "^32.1.0",
    "@alialkhtri3-png/sip-sdk": "^1.0.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^14.0.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alialkhtri3-png/farcaster-ens.git"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "keccak@3.0.4": true,
    "secp256k1@4.0.4": true
  },
  "devDependencies": {
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "ethers": "^5.7.2",
    "hardhat": "^2.22.19",
    "solc": "^0.8.20"
  },
  "type": "module"
}
